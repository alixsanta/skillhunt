{
    "name": "skillhunt-backend-core",
    "version": "1.0.0",
    "description": "SkillHunt Monolith Backend Core",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/main.js",
        "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
        "lint": "eslint src/**/*.ts",
        "test": "jest",
        "typeorm": "ts-node ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
        "migration:run": "npm run typeorm -- migration:run",
        "migration:revert": "npm run typeorm -- migration:revert",
        "migration:generate": "npm run typeorm -- migration:generate"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1075.0",
        "@aws-sdk/s3-request-presigner": "^3.1075.0",
        "@nestjs/common": "^11.1.27",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.27",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/platform-express": "^11.1.27",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/typeorm": "^11.0.2",
        "@node-rs/argon2": "^2.0.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "dotenv": "^17.4.2",
        "multer": "^2.2.0",
        "pdf-lib": "^1.17.1",
        "pg": "^8.22.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.1",
        "swagger-ui-express": "^5.0.0",
        "typeorm": "^1.0.0"
    },
    "overrides": {
        "multer": "^2.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@nestjs/testing": "^11.1.27",
        "@types/express": "^5.0.0",
        "@types/geojson": "^7946.0.16",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.0.0",
        "eslint": "^9.39.4",
        "jest": "^30.4.2",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.61.1"
    }
}
