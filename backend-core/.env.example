# --- SkillHunt backend-core : variables d'environnement ---
# Copier en .env (git-ignoré) et renseigner. NE JAMAIS committer de vraie clé.

# Port d'écoute de l'API (défaut : 3001)
PORT=3001

# --- Base de données PostgreSQL + PostGIS (SH-6) ---
# Valeurs par défaut alignées sur docker-compose.yml (dev). NE JAMAIS committer de vrais identifiants.
DB_HOST=localhost
# Port HÔTE (cf. docker-compose.yml). 5433 par défaut pour éviter un PostgreSQL natif sur 5432.
DB_PORT=5433
DB_USERNAME=skillhunt
DB_PASSWORD=skillhunt
DB_NAME=skillhunt
# Mettre à 'true' pour logger les requêtes SQL (debug)
DB_LOGGING=false

# --- JWT RS256 ---
# Clés RSA au format PEM (ou base64 du PEM). Générer une paire :
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Puis coller le contenu (les \n peuvent être échappés sur une seule ligne).
# Si ces variables sont absentes, une paire ÉPHÉMÈRE est générée au démarrage (dev uniquement).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- Stockage objet S3 (SH-31) ---
# Bucket PRIVÉ uniquement (jamais d'ACL publique). Accès via Signed URL courte.
# NE JAMAIS committer de vraie clé AWS.
AWS_REGION=eu-west-3
AWS_S3_BUCKET=skillhunt-media
# Endpoint S3 :
#   - DEV/TEST : http://localhost:4566 (LocalStack, cf. docker-compose.yml)
#   - PROD     : laisser VIDE pour cibler AWS S3 réel (sans changement de code)
AWS_S3_ENDPOINT=http://localhost:4566
# Credentials. En dev avec LocalStack, n'importe quelle valeur non vide convient ('test').
# En prod : utiliser un rôle IAM / secret manager — jamais de clé en dur dans le code.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
